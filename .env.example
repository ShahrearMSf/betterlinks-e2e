# BetterLinks E2E — environment template
# Copy to .env and fill in your values; .env is gitignored.

# Base URL of the target WordPress site (no trailing slash)
BASE_URL=https://your-site.example

# WordPress admin credentials used by tests/auth.setup.js
# Either a username or an email works, as long as it's a user with
# `manage_options` on the target site.
ADMIN_USER=admin-username-or-email
ADMIN_PASS=your-admin-password
